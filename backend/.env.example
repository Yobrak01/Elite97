# ====================================================
# Elite97 Backend — Environment Variables
# ====================================================
# Set these in Render Dashboard or your server
# ====================================================

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/elite97

# JWT signing secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here

# Google Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Email configuration (for OTP emails — optional if OTP disabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_gmail_app_password

# Node environment
NODE_ENV=production

# Port (Render sets this automatically)
PORT=5000
